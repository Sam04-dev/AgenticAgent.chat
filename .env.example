# ── Vertex Sentinel: Environment Template ──────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file.

# Agent private key (for EIP-712 signing and on-chain interactions)
AGENT_PRIVATE_KEY=0x...your_agent_private_key_here

# General private key (fallback for scripts/deployment)
PRIVATE_KEY=0x...your_general_private_key_here

# Network (e.g., sepolia, mainnet)
NETWORK=sepolia

# Rollout Phase (alpha | beta | public)
ROLLOUT_PHASE=alpha
MAX_USERS=5

# Strykr PRISM API key (canonical asset resolution)
STRYKR_PRISM_API=prism_sk_...your_api_key_here

# Infura API key (for Sepolia deployment and connectivity)
INFURA_KEY=...your_infura_key_here

# Optimization Phase: RPC Endpoints
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/...your_infura_key_here
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/...your_alchemy_key_here
MAINNET_RPC=https://mainnet.infura.io/v3/...your_infura_key_here
BASE_RPC=https://mainnet.base.org
ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/...your_alchemy_key_here

# Agent Metadata URI (Publicly accessible URL to agent metadata)
AGENT_METADATA_URI=https://github.com/.../metadata.json

# Engineering & Network Configuration (Optional)
TX_CONFIRMATION_TIMEOUT=90000
LOCAL_RPC_URL="http://127.0.0.1:8545"

# AI Provider Selection (google | groq)
# Defaults to google if not set.
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Groq AI API key (Recommended default)
GROQ_API_KEY=gsk_...your_groq_key_here

# Google AI API key (Optional fallback)
# The googleai plugin expects GOOGLE_GENAI_API_KEY
GOOGLE_GENAI_API_KEY=...your_google_ai_key_here

# AgentStack Integration (Required for Mainnet/Arc L1 Verification)
# Set to 'false' only for local/test environments
AGENTSTACK_REQUIRED=true
AGENT_STACK_URL=http://localhost:3003

# Kraken API Credentials (for live trading execution)
KRAKEN_API_KEY=...your_kraken_api_key_here
KRAKEN_SECRET=...your_kraken_secret_here

# Kraken Paper Mode (set to 'true' for simulated trading, no real money)
KRAKEN_PAPER_MODE=false

# Optional: Override path to kraken binary (defaults to 'kraken' in PATH)
# KRAKEN_CLI_PATH=kraken

# Circle WaaS Integration (Day 3-5 Security Hardening)
USE_CIRCLE_WAAS=false
CIRCLE_API_KEY=...
CIRCLE_ENTITY_SECRET=...
AGENT_WALLET_ID=...
AGENT_WALLET_ADDRESS=...

# Multi-channel Alerts
SENDGRID_API_KEY=...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# High-Stakes Human-in-the-Loop (HITL) Threshold
HITL_THRESHOLD_USD=1000

# API Key Management
API_KEY_SECRET=your-secure-secret-here

# Binance Adapter
BINANCE_API_KEY=your-binance-key
BINANCE_SECRET=your-binance-secret
BINANCE_BASE_URL=https://api.binance.com

# Risk Sizing
KELLY_FRACTION=0.25
