{
  "name": "agenticagent-chat",
  "version": "1.0.0",
  "description": "AgenticAgent.chat - the trusted communication network for autonomous AI agents. EIP-712 signed TaskIntents, on-chain agent trust layer, and fail-closed delegation.",
  "type": "module",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgenticAgentChat/agenticagent-chat.git"
  },
  "scripts": {
    "build": "npx tsc",
    "generate:types": "node scripts/generate_types.js",
    "start": "npm run generate:types && NODE_OPTIONS='--import tsx --no-warnings' npx ts-node src/logic/agent_brain.ts",
    "compile": "npx hardhat compile",
    "test": "NODE_ENV=test NODE_OPTIONS='--import tsx --no-warnings' npx hardhat test test/RiskRouter.test.ts test/contracts/*.test.ts && NODE_ENV=test NODE_OPTIONS='--import tsx --no-warnings' npx mocha test/**/*.test.ts --exclude 'test/RiskRouter.test.ts' --exclude 'test/contracts/*.test.ts'",
    "demo": "NODE_OPTIONS='--import tsx --no-warnings' npx hardhat run scripts/demo_flow.ts --network hardhat",
    "register": "NODE_OPTIONS='--import tsx --no-warnings' npx hardhat run scripts/deploy_sepolia.ts --network sepolia",
    "onboard:sepolia": "NODE_OPTIONS='--import tsx --no-warnings' npx hardhat run scripts/deploy_sepolia.ts --network sepolia",
    "submit:sepolia": "NETWORK=sepolia NODE_OPTIONS='--import tsx --no-warnings' npx hardhat run scripts/deploy_sepolia.ts --network sepolia",
    "test:e2e": "NODE_ENV=test NODE_OPTIONS='--import tsx --no-warnings' npx mocha --timeout 15000 test/e2e/pnl_scenario.test.ts",
    "test:stress": "NODE_OPTIONS='--import tsx --no-warnings' npx ts-node scripts/stress_test_cycle.ts",
    "node": "npx hardhat node",
    "dashboard": "npm start",
    "prepare": "bash scripts/setup-hooks.sh"
  },
  "keywords": [
    "agent-network",
    "autonomous-agents",
    "agent-to-agent",
    "eip-712",
    "ethereum",
    "agent-trust-layer",
    "smart-contracts",
    "agent-identity",
    "mcp",
    "fail-closed"
  ],
  "author": "AgenticAgent.chat <info.agenticagentchat@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/AgenticAgentChat/agenticagent-chat#readme",
  "bugs": {
    "url": "https://github.com/AgenticAgentChat/agenticagent-chat/issues"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.3.0",
    "@genkit-ai/google-genai": "^1.31.0",
    "@google-cloud/firestore": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/cors": "^2.8.19",
    "@types/node-fetch": "^2.6.13",
    "@types/sqlite3": "^5.1.0",
    "axios": "^1.15.2",
    "ccxt": "^4.5.46",
    "chai": "^4.3.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.7.0",
    "fluent-ffmpeg": "^2.1.3",
    "genkit": "^1.31.0",
    "genkitx-groq": "^0.30.0",
    "node-fetch": "^3.3.2",
    "serve": "^14.2.6",
    "sinon": "^21.0.3",
    "sqlite3": "^6.0.1",
    "ts-node": "^10.9.2",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/hardhat-viem": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@playwright/test": "^1.59.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/nock": "^10.0.3",
    "@types/node": "^25.8.0",
    "@types/sinon": "^21.0.1",
    "@types/ws": "^8.18.1",
    "ethers": "^6.10.0",
    "hardhat": "^2.28.6",
    "hardhat-gas-reporter": "^1.0.10",
    "json-schema-to-typescript": "^15.0.4",
    "nock": "^14.0.14",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "solidity-coverage": "^0.8.17",
    "tsx": "^4.22.0",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3",
    "viem": "^2.52.2",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  }
}
